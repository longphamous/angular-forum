# Copy this file to .env and fill in the values
PORT=3000
NODE_ENV=development

# ─── PostgreSQL (main database) ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=aniverse_app
DB_PASSWORD=<your_db_password>
DB_NAME=aniverse_base
DB_SCHEMA=public
DB_SSL=false

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=<generate_a_random_secret>

# ─── Anime DB (secondary read-only database) ────────────────────────────────
ANIME_DB_HOST=localhost
ANIME_DB_PORT=5432
ANIME_DB_USER=<your_anime_db_user>
ANIME_DB_PASSWORD=<your_anime_db_password>
ANIME_DB_NAME=<your_anime_db_name>
ANIME_DB_SCHEMA=public

# ─── Push / WebSocket ────────────────────────────────────────────────────────
PUSH_ENABLED=true
