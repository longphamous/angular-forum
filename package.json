{
  "name": "aniverse",
  "version": "0.0.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "postinstall": "pnpm dlx husky@latest install",
    "ng": "ng",
    "start": "nx serve angular-forum",
    "start:mock": "nx serve angular-forum --configuration=mock",
    "start:backend": "nx serve base",
    "build": "nx build",
    "build:production": "nx build --configuration production",
    "build:forum": "nx build angular-forum --configuration production",
    "build:forum:mock": "nx build angular-forum --configuration mock",
    "build:animedb": "nx build anime-db --configuration production",
    "watch": "nx build --watch --configuration development",
    "test": "nx test",
    "lint": "pnpm exec prettier --check . && pnpm exec eslint . --max-warnings=0",
    "lint:fix": "node scripts/lint.mjs",
    "lint:fix:forum": "node scripts/lint.mjs angular-forum",
    "lint:fix:anime-db": "node scripts/lint.mjs anime-db",
    "lint:fix:shared": "node scripts/lint.mjs shared",
    "lint:fix:base": "node scripts/lint.mjs base",
    "lint:check": "node scripts/lint.mjs --no-fix",
    "lint:check:forum": "node scripts/lint.mjs angular-forum --no-fix",
    "lint:check:anime-db": "node scripts/lint.mjs anime-db --no-fix",
    "lint:check:shared": "node scripts/lint.mjs shared --no-fix",
    "lint:check:base": "node scripts/lint.mjs base --no-fix",
    "format": "pnpm exec prettier --write ."
  },
